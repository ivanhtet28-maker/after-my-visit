{
  "manifest_version": 3,
  "name": "Clarity Health — GP Note Sender",
  "description": "Paste a consult note or script and send it straight to a patient's Clarity dashboard.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Clarity — Send Note",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.supabase.co/*"
  ]
}
